# daily-review-auto.sh 用の環境変数サンプル
#
# 使い方:
#   cp .env.example .env.local
#   .env.local に実際の値を記入する（.env.local は .gitignore 済み）
#
# Rocket Chat の認証情報は、ブラウザで team.ebase-jp.com にログイン後、
# Personal Access Token を発行して取得するか、既存の認証トークンを流用する。

# Rocket Chat 本体の REST API ベース URL
RC_BASE_URL="https://team.ebase-jp.com"

# Rocket Chat 認証トークン（X-Auth-Token ヘッダに使う）
RC_TOKEN=""

# Rocket Chat ユーザー ID（X-User-Id ヘッダに使う）
RC_USER_ID=""

# 取得対象のチャンネル（times）名
RC_CHANNEL="mori.a-times"
